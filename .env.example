# MetaCut 环境变量示例
# 复制为 .env.local 并填入真实值（切勿提交到 git）

# Step1 视频解析 + Step2 商品多模态拆解（Doubao）
DOUBAO_APIKEY=your_doubao_api_key
DOUBAO_EP=your_doubao_endpoint_id
# DOUBAO_PRODUCT_MODEL=doubao-seed-2-0-lite
# METACUT_PROMPT_PRODUCT_SYSTEM=（可选，覆盖 docs/prompts/02-product-parse.system.md）

# 百炼 DashScope（万相2.6 生图 + 生视频，与百炼 MCP 工具一致）
DASHSCOPE_API_KEY=your_dashscope_api_key
# 国内默认；国际可改为 https://dashscope-intl.aliyuncs.com/api/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 百炼拉取本地素材用的公网 Origin（Sealos/域名/ngrok），勿填 localhost
METACUT_PUBLIC_ORIGIN=https://your-public-domain.example.com

# 公网评审版持久化（PostgreSQL）
DATABASE_URL=postgresql://user:password@host:5432/database

# Sealos / S3 兼容对象存储（真实密钥只放部署环境或 .env.local）
S3_ENDPOINT_INTERNAL=http://object-storage.objectstorage-system.svc.cluster.local
S3_ENDPOINT_EXTERNAL=https://objectstorageapi.example.com
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=f7g0mc0f-jennie
S3_PREFIX=metacut

# 外部评审访问码
METACUT_REVIEW_ACCESS_CODE=change_me

# 万相2.6 生图：文生图 t2i / 有参考图时用图像编辑 image
WAN26_T2I_MODEL=wan2.6-t2i
WAN26_IMAGE_MODEL=wan2.6-image
WAN26_IMAGE_SIZE=720*1280

# 万相2.6 生视频（文生视频 / 图生视频 / 参考生视频）
WAN26_T2V_MODEL=wan2.6-t2v
WAN26_I2V_MODEL=wan2.6-i2v-flash
WAN26_R2V_MODEL=wan2.6-r2v-flash
WAN26_VIDEO_SIZE=720*1280
WAN26_VIDEO_RESOLUTION=720P
WAN26_VIDEO_RATIO=9:16

# 渲染：有 DASHSCOPE_API_KEY 且未设 METACUT_RENDER_MOCK=true 时走百炼
# METACUT_RENDER_MOCK=true

# DashScope 轮询
DASHSCOPE_POLL_INTERVAL_MS=15000
DASHSCOPE_POLL_TIMEOUT_MS=600000
